#!/usr/bin/env python3
"""Homelab Control API — lightweight HTTP service for safe system management.

Endpoints:
    GET  /                → Web control panel (token required via query param)
    GET  /health          → 200 OK (no auth required)
    POST /shutdown        → stop containers, power off
    POST /restart         → stop containers, reboot
    POST /update          → pull & restart containers
    POST /clean           → prune unused Docker resources

All POST endpoints require: Authorization: Bearer <token>
Web panel requires: /?token=<token>
"""

import http.server
import json
import os
import subprocess
import sys
from urllib.parse import parse_qs, urlparse

TOKEN = "{{ homelab_control_token }}"
PORT = {{ homelab_control_port }}

