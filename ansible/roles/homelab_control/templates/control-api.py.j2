def run(cmd, timeout=120):
    """Run a shell command and return (returncode, stdout, stderr)."""
    try:
        result = subprocess.run(
            cmd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        return result.returncode, result.stdout, result.stderr
    except subprocess.TimeoutExpired:
        return 1, "", "Command timed out"


class Handler(http.server.BaseHTTPRequestHandler):
    """Handle incoming HTTP requests for homelab control actions."""

    def _send_json(self, code, data):
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def _send_html(self, code, html):
        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.end_headers()
        self.wfile.write(html.encode())

    def _check_auth(self):
        auth = self.headers.get("Authorization", "")
        if auth != f"Bearer {TOKEN}":
            self._send_json(401, {"error": "unauthorized"})
            return False
        return True

    def _check_token_param(self):
        """Check token from query parameter for web panel access."""
        parsed = urlparse(self.path)
        params = parse_qs(parsed.query)
        token = params.get("token", [""])[0]
        return token == TOKEN

    def do_GET(self):  # noqa: N802
        parsed = urlparse(self.path)

        if parsed.path == "/":
            if self._check_token_param():
                self._send_html(200, PANEL_HTML)
            else:
                self._send_json(401, {"error": "unauthorized"})
        elif parsed.path == "/health":
            self._send_json(200, {"status": "ok"})
        else:
            self._send_json(404, {"error": "not found"})

    def do_POST(self):  # noqa: N802
        if not self._check_auth():
            return

        actions = {
            "/shutdown": self._shutdown,
            "/restart": self._restart,
            "/update": self._update,
            "/clean": self._clean,
        }

        action = actions.get(self.path)
        if action:
            action()
        else:
            self._send_json(404, {"error": "not found"})

    def _shutdown(self):
        self._send_json(200, {"status": "shutting down"})
        os.system("sudo {{ homelab_control_dir }}/shutdown.sh &")

    def _restart(self):
        self._send_json(200, {"status": "restarting"})
        os.system("sudo {{ homelab_control_dir }}/restart.sh &")

    def _update(self):
        results = []
        for d in COMPOSE_DIRS:
            if os.path.isfile(os.path.join(d, "docker-compose.yml")):
                rc, out, err = run(f"docker compose -f {d}/docker-compose.yml pull")
                run(f"docker compose -f {d}/docker-compose.yml up -d")
                results.append({"dir": d, "rc": rc, "output": out.strip()})
        self._send_json(200, {"status": "updated", "results": results})

    def _clean(self):
        rc, out, _ = run("docker system prune -af --volumes=false")
        self._send_json(200, {"status": "cleaned", "output": out.strip()})

    def log_message(self, format, *args):  # noqa: A002
        """Log to stdout for journald capture."""
        sys.stderr.write(f"[control-api] {args[0]} {args[1]} {args[2]}\n")


if __name__ == "__main__":
    server = http.server.HTTPServer(("0.0.0.0", PORT), Handler)
    print(f"Homelab Control API listening on port {PORT}")
    server.serve_forever()
