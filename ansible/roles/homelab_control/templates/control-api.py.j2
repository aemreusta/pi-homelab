function startRebootPolling() {
  let phase = 'waiting'; // waiting → offline → recovering
  let offlineAt = 0;

  rebootPollTimer = setInterval(async function() {
    const status = document.getElementById('rebootStatus');
    const bar = document.getElementById('rebootBar');
    const icon = document.getElementById('rebootIcon');
    const title = document.getElementById('rebootTitle');
    const desc = document.getElementById('rebootDesc');

    try {
      const r = await fetch('/health', { signal: AbortSignal.timeout(3000) });
      const d = await r.json();

      if (phase === 'offline') {
        // System was offline and now it's back!
        phase = 'recovering';
        status.textContent = 'API is back, waiting for services';
        bar.className = 'reboot-progress-bar';
        bar.style.width = '80%';
      }

      if (phase === 'recovering' || (phase === 'waiting' && (Date.now() - rebootStartTime) > 5000)) {
        // System is online — show success
        clearInterval(rebootPollTimer);
        rebootPollTimer = null;
        showRebootSuccess();
