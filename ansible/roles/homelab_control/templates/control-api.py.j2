    "/home/{{ docker_user }}/docker/network/adguard",
    "/home/{{ docker_user }}/docker/core/portainer",
    "/home/{{ docker_user }}/docker/core/glances",
    "/home/{{ docker_user }}/docker/core/homepage",
    "/home/{{ docker_user }}/docker/core/filebrowser",
    "/home/{{ docker_user }}/docker/core/watchtower",
    "/home/{{ docker_user }}/docker/media",
]

