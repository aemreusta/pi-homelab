---
# Maintainerr — auto-delete watched media from Jellyfin via Sonarr/Radarr
# https://github.com/jorenn92/maintainerr

services:
  maintainerr:
    image: ghcr.io/jorenn92/maintainerr:latest
    container_name: maintainerr
    restart: unless-stopped
    user: "1000:1000"
    environment:
      - TZ={{ maintainerr_tz }}
    ports:
      - "{{ maintainerr_port }}:6246"
    volumes:
      - {{ maintainerr_config_dir }}:/opt/data
    networks:
      - maintainerr_net

networks:
  maintainerr_net:
    driver: bridge
